# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_api_key_here
EVOLUTION_INSTANCE_NAME=triage-bot

# WhatsApp Group
TARGET_GROUP_JID=                      # Format: 1234567890-1234567890@g.us

# Anthropic
ANTHROPIC_API_KEY=

# Google Cloud Vision
GOOGLE_CLOUD_CREDENTIALS_JSON=         # Base64-encoded service account JSON

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=screenshots

# Server
PORT=3000
WEBHOOK_SECRET=                        # Random string, set in Evolution API config too
